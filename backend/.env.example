# ExamShield AI – Backend environment configuration
# Copy this file to `.env` and edit the values for your setup.

# ====== Database ======
# Option 1: Use MySQL (recommended for production)
# DATABASE_URL=mysql+pymysql://root:AbhiKm@1998localhost:3306/examshield
DATABASE_URL=mysql+pymysql://root:AbhiKm%401998@localhost:3306/examshield_db



# Option 2: Use local SQLite (no setup needed) — comment out the MySQL line above and uncomment below
# DATABASE_URL=sqlite:///./examshield.db

# ====== JWT Security ======
SECRET_KEY=replace-with-a-long-random-secret-key-for-jwt
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ====== AI Chatbot (optional) ======
# Get an OpenAI key from https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Or a Gemini key from https://makersuite.google.com/app/apikey
GEMINI_API_KEY=
